# Project
GDP_PROJECT_NAME=cloud-native-game-discovery-platform

# Database
GDP_DB_HOST=localhost
GDP_DB_PORT=5432
GDP_DB_NAME=gamedb
GDP_DB_USER=gameuser
GDP_DB_PASSWORD=gamepass

# Ports
GDP_BACKEND_PORT=8000
GDP_FRONTEND_PORT=3000

# RAWG API
GDP_RAWG_API_KEY=your_rawg_api_key

# Ingestion
GDP_INGEST_PAGE_SIZE=20

# GCP / Vertex AI
GDP_GCP_PROJECT_ID=your-gcp-project-id
GDP_GCP_LOCATION=us-central1
GDP_EMBEDDING_MODEL=gemini-embedding-001

# App behavior
GDP_QUERY_CACHE_FILE=query_cache.json
GDP_LOG_LEVEL=INFO
